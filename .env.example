# Copy to app/.env for local dev, and set these as Environment Variables in Vercel.

# Neon POOLED connection string (from Neon dashboard → Connection Details → "Pooled connection").
# The pooled endpoint (…-pooler…) is important for serverless.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Flask session signing key — use a long random string (e.g. `python -c "import secrets;print(secrets.token_hex(32))"`).
SECRET_KEY=change-me-to-a-long-random-string

# Initial login password seeded onto every user by setup_auth.py. Rotate after first login.
SEED_PASSWORD=set-a-strong-initial-password
